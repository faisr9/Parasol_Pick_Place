<?xml version="1.0"?>
<robot name="red_cube_robot">

  <material name="red">
    <color rgba="1.0 0.0 0.0 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.0417" ixy="0.0" ixz="0.0" iyy="0.0417" iyz="0.0" izz="0.0417"/>
    </inertial>
  </link>

</robot>
